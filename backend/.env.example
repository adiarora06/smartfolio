# SmartFolio backend configuration. Copy to `.env` for local use, or set these
# in your host's dashboard (Render/Railway). All are optional — with no key the
# app serves offline reference prices.

# Market data provider: "alphavantage" or "finnhub".
MARKET_DATA_PROVIDER=alphavantage
# Your free key. Leave blank for offline-only.
#   Alpha Vantage: https://www.alphavantage.co/support/#api-key
#   Finnhub:       https://finnhub.io/register
MARKET_DATA_API_KEY=
# Seconds to cache each quote in-process (protects free-tier request budgets).
MARKET_DATA_CACHE_TTL=900
# Per-request provider network timeout (seconds).
MARKET_DATA_TIMEOUT=6

# Comma-separated browser origins allowed by CORS. Add your deployed frontend.
SMARTFOLIO_CORS_ORIGINS=http://localhost:5173,https://smartfolio-lemon.vercel.app
