# SmartFolio backend configuration. Copy to `.env` for local use, or set these
# in your host's dashboard (Render/Railway). All are optional — with no key the
# app serves offline reference prices.

# Market data provider: "alphavantage" or "finnhub".
MARKET_DATA_PROVIDER=alphavantage
# Your free key. Leave blank for offline-only.
#   Alpha Vantage: https://www.alphavantage.co/support/#api-key
#   Finnhub:       https://finnhub.io/register
MARKET_DATA_API_KEY=
# Seconds to cache each quote in-process (protects free-tier request budgets).
MARKET_DATA_CACHE_TTL=900
# Per-request provider network timeout (seconds).
MARKET_DATA_TIMEOUT=6

# LLM Provider: "anthropic" (Claude) or "openai" (GPT). Defaults to anthropic.
LLM_PROVIDER=anthropic

# Anthropic API key for Claude models (get at https://console.anthropic.com)
# Leave blank to disable Claude
ANTHROPIC_API_KEY=

# OpenAI API key for GPT models (get at https://platform.openai.com/api-keys)
# Leave blank to disable OpenAI
OPENAI_API_KEY=

# LLM Model to use (depends on provider):
#   For Anthropic: claude-opus-4-8, claude-sonnet-5, claude-haiku-4-5
#   For OpenAI:    gpt-4o, gpt-4o-mini, gpt-4-turbo
LLM_MODEL=claude-opus-4-8

# Max tokens per LLM response
LLM_MAX_TOKENS=1024

# Per-request LLM timeout (seconds)
LLM_TIMEOUT=10

# Plaid brokerage sync. FREE sandbox keys: https://dashboard.plaid.com
# (Team Settings -> Keys). Sandbox works end-to-end with fake institutions
# (credentials user_good / pass_good). Leave blank -> demo toggle only.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox

# Persistence. Defaults to a local SQLite file (zero setup, but wiped on each
# Render redeploy). For durable cloud persistence, set a Neon/Postgres URL —
# postgres:// and ?sslmode=... are normalized automatically.
#   e.g. postgresql://user:pass@ep-xxx.neon.tech/smartfolio
DATABASE_URL=

# Error tracking (optional). Set a Sentry DSN to capture exceptions; blank = off.
SENTRY_DSN=

# Comma-separated browser origins allowed by CORS. Add your deployed frontend.
SMARTFOLIO_CORS_ORIGINS=http://localhost:5173,https://smartfolio-lemon.vercel.app
